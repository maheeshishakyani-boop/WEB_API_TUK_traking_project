# ========================================
# TUK-TUK API - ENVIRONMENT VARIABLES
# ========================================
NODE_ENV=development

# Server
PORT=3000

# MySQL Database (change these to match your MySQL setup)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tuktuk_db
DB_USER=root
DB_PASS=123456

# JWT Secret (change this to any long random string)
JWT_SECRET=tuktuk_super_secret_key_change_this_123456
JWT_EXPIRE=24h


ALLOWED_ORIGINS=http://localhost:3000,https://webapituktrakingproject-production.up.railway.app
